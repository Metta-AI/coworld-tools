*.egg-info/
__pycache__/
.eval_results/
.benchmarks/
.pytest_cache/
.ruff_cache/
.venv/
.nimcache/
nimcache/
*.pyc
*.dylib
*.so
*.o

# macOS
.DS_Store

# Claude Code session locks
**/.claude/scheduled_tasks.lock

# Coworld manifest/image cache downloaded by `coworld download` (see e.g.
# policies/cyborg/bitworld/coborg_among_them/scripts/play_local.sh).
/coworld/

# Nimby-generated FFI bindings and path-config for nim_agents builds.
# (Hand-written nim.cfg elsewhere, e.g. guided_bot/nim.cfg, stays tracked.)
**/nim_agents/bindings/
**/nim_agents/nim.cfg

# Per-user ephemeral run outputs (coworld replays, smoke-test logs, etc.).
users/**/tmp/
