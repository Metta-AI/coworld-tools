{
  "$schema": "https://opencode.ai/config.json",
  "model": "amazon-bedrock/anthropic.claude-sonnet-4-6",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "{env:AWS_REGION}",
        "profile": "{env:AWS_PROFILE}"
      }
    }
  },
  "enabled_providers": ["amazon-bedrock"],
  "instructions": ["AGENT_INSTRUCTIONS.md"],
  "permission": {
    "edit": "allow",
    "write": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow"
  },
  "snapshot": false,
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "watcher": {
    "ignore": ["node_modules/**", ".git/**", "__pycache__/**", "*.pyc", "snapshots/**"]
  }
}
