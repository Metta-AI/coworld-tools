{
  "name": "persephones-escape",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "start:tournament": "tsx server.ts --mode=tournament",
    "start:replay": "tsx server.ts --mode=replay",
    "start:simple": "tsx server.ts --config=simple",
    "start:medium": "tsx server.ts --config=medium",
    "dev": "tsx watch server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "snappyjs": "^0.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/snappyjs": "^0.7.1",
    "@types/ws": "^8.5.0",
    "canvas": "^3.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
