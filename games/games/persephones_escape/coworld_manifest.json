{
  "$schema": "./schemas/coworld_manifest_schema.json",
  "game": {
    "manifest_uri": "game/cogame_manifest.json"
  },
  "player": [
    {
      "id": "idle-player",
      "name": "Idle Player",
      "image_uri": "persephones-escape-player:latest",
      "description": "Baseline Coworld player that connects to the assigned slot and emits no-op inputs until the episode ends."
    }
  ],
  "variants": [
    {
      "id": "tournament-smoke",
      "name": "Tournament Smoke",
      "game_config": {
        "mode": "tournament",
        "seed": 42,
        "roles": [
          { "role": "Hades", "team": "TeamA", "count": 1 },
          { "role": "Persephone", "team": "TeamB", "count": 1 },
          { "role": "Cerberus", "team": "TeamA", "count": 1 },
          { "role": "Demeter", "team": "TeamB", "count": 1 },
          { "role": "Shades", "team": "TeamA", "count": 1 },
          { "role": "Nymphs", "team": "TeamB", "count": 1 }
        ],
        "rounds": [
          { "durationSecs": 1, "hostages": 1 }
        ],
        "obstacleCount": 0,
        "autoGrantWhisperEntry": true,
        "fastTimers": true
      },
      "description": "Short deterministic six-slot tournament configuration used for Coworld certification."
    }
  ],
  "certification": {
    "variant_id": "tournament-smoke",
    "players": [
      { "player_id": "idle-player", "initial_params": { "name": "slot_0" } },
      { "player_id": "idle-player", "initial_params": { "name": "slot_1" } },
      { "player_id": "idle-player", "initial_params": { "name": "slot_2" } },
      { "player_id": "idle-player", "initial_params": { "name": "slot_3" } },
      { "player_id": "idle-player", "initial_params": { "name": "slot_4" } },
      { "player_id": "idle-player", "initial_params": { "name": "slot_5" } }
    ]
  }
}
