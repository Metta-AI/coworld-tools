{
  "$schema": "../schemas/cogame_manifest_schema.json",
  "name": "persephones-escape",
  "version": "0.1.0",
  "description": "A hidden-role social deduction game about Hades, Persephone, hostage exchanges, and private information sharing.",
  "owner": "cogames@softmax.com",
  "image_uri": "persephones-escape-game:latest",
  "config_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "required": ["mode", "tokens", "roles", "rounds"],
    "properties": {
      "mode": { "const": "tournament" },
      "tokens": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "seed": { "type": "integer" },
      "roles": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "team", "count"],
          "properties": {
            "role": {
              "oneOf": [
                { "type": "integer", "minimum": 0, "maximum": 10 },
                {
                  "type": "string",
                  "enum": [
                    "Hades", "Persephone", "Cerberus", "Demeter", "Shades", "Nymphs", "Spy",
                    "EchoOfHades", "EchoOfPersephone", "EchoOfCerberus", "EchoOfDemeter",
                    "Echo of Hades", "Echo of Persephone", "Echo of Cerberus", "Echo of Demeter"
                  ]
                }
              ]
            },
            "team": {
              "oneOf": [
                { "type": "integer", "minimum": 0, "maximum": 1 },
                { "type": "string", "enum": ["TeamA", "TeamB"] }
              ]
            },
            "count": { "type": "integer", "minimum": 1 }
          }
        }
      },
      "rounds": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["durationSecs", "hostages"],
          "properties": {
            "durationSecs": { "type": "number", "exclusiveMinimum": 0 },
            "hostages": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "obstacleCount": { "type": "integer", "minimum": 0 },
      "chatMaxCharsPerLine": { "type": "integer", "minimum": 1 },
      "actionRateLimits": {
        "type": "object",
        "additionalProperties": { "type": "number", "minimum": 0 }
      },
      "groupNamePrefixInRoomA": { "type": "string" },
      "autoGrantWhisperEntry": { "type": "boolean" },
      "fastTimers": { "type": "boolean" }
    }
  },
  "results_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "required": ["scores", "winner", "players", "ticks"],
    "properties": {
      "scores": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "number" }
      },
      "winner": { "type": "string", "enum": ["Shades", "Nymphs", "Draw"] },
      "players": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["slot", "name", "team", "score"],
          "properties": {
            "slot": { "type": "integer", "minimum": 0 },
            "name": { "type": "string" },
            "team": { "type": "string", "enum": ["Shades", "Nymphs"] },
            "score": { "type": "number" }
          }
        }
      },
      "ticks": { "type": "integer", "minimum": 0 }
    }
  },
  "protocols": {
    "player": "../docs/player_protocol_spec.md",
    "global": "../docs/global_protocol_spec.md"
  }
}
