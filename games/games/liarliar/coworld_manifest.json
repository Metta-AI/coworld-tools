{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "game": {
    "name": "liar-liar-cut-the-wire",
    "version": "0.1.0",
    "description": "A browser-first distributed-manual bomb game with direct communication, redundant hints, and individual scoring.",
    "owner": "kyle@softmax.com",
    "runnable": {
      "type": "game",
      "image": "liarliar-coworld:latest",
      "run": ["node", "/app/src/server.js"]
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": ["tokens", "players", "duration_seconds", "tick_rate", "player_connect_timeout_seconds", "hint_redundancy", "communication_graph", "hint_graph", "seed"],
      "properties": {
        "tokens": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1 }
        },
        "players": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 }
            }
          }
        },
        "duration_seconds": { "type": "integer", "minimum": 10, "maximum": 1800 },
        "tick_rate": { "type": "number", "exclusiveMinimum": 0, "maximum": 10 },
        "player_connect_timeout_seconds": { "type": "number", "minimum": 0, "maximum": 300 },
        "hint_redundancy": { "type": "number", "minimum": 1, "maximum": 5 },
        "communication_graph": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type"],
          "properties": {
            "type": { "type": "string" }
          }
        },
        "hint_graph": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type"],
          "properties": {
            "type": { "type": "string" }
          }
        },
        "seed": { "type": "string", "minLength": 1 }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": ["scores", "survived", "detonated", "modules_solved", "modules_failed", "rps_outcomes", "hint_recoveries", "duration_seconds"],
      "properties": {
        "scores": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "number" }
        },
        "survived": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "boolean" }
        },
        "detonated": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "boolean" }
        },
        "modules_solved": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "integer", "minimum": 0 }
        },
        "modules_failed": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "integer", "minimum": 0 }
        },
        "rps_outcomes": { "type": "array" },
        "hint_recoveries": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "type": "integer", "minimum": 0 }
        },
        "duration_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "protocols": {
      "player": {
        "type": "text",
        "value": "Connect to WEBSOCKET /player?slot=<slot>&token=<token>. The server sends {type:'view', view:<canonical JSON>} and {type:'final', results}. In the lobby, clients send {type:'ready', ready:true|false}; play begins when all fixed slots are connected and ready. During play, clients may send direct chat {type:'chat', to, text} or operate a module {type:'operate', moduleId, action}. There is no verifiable hint-sharing action; any hint transfer is ordinary direct chat. All legal module actions are listed in view.legalActions."
      },
      "global": {
        "type": "text",
        "value": "Connect to WEBSOCKET /global for observer state only. This is not a player communication channel. The server sends {type:'global', state:<canonical JSON>} snapshots with scores, bombs, graph, and recent events."
      }
    },
    "docs": {
      "readme": {
        "type": "text",
        "value": "Liar Liar, Cut the Wire! is a distributed-manual bomb game. Each player sees their own bomb and hints for other players. Players can communicate only over direct graph-limited channels."
      },
      "pages": []
    }
  },
  "player": [
    {
      "id": "scripted-helper",
      "name": "Scripted Helper",
      "type": "player",
      "image": "liarliar-coworld:latest",
      "run": ["node", "/app/src/bot/index.js"],
      "description": "Shares visible manual pieces to their targets and solves modules from received canonical JSON hints."
    }
  ],
  "grader": [
    {
      "id": "liarliar-grader",
      "name": "Liar Liar Grader",
      "type": "grader",
      "description": "Reference Liar Liar grader that scores module outcomes, survival, detonations, score spread, and communication signals.",
      "source_url": "https://github.com/Metta-AI/graders/tree/main/graders/liarliar/liarliar_grader",
      "image": "ghcr.io/metta-ai/graders-liarliar:latest"
    }
  ],
  "variants": [
    {
      "id": "default-5m",
      "name": "Default 5 Minute 6P",
      "game_config": {
        "seed": "liarliar-default",
        "duration_seconds": 300,
        "tick_rate": 1,
        "player_connect_timeout_seconds": 60,
        "hint_redundancy": 1.3,
        "communication_graph": { "type": "circle", "radius": 2 },
        "hint_graph": { "type": "circle", "radius": 2 },
        "players": [
          { "name": "Player 1" },
          { "name": "Player 2" },
          { "name": "Player 3" },
          { "name": "Player 4" },
          { "name": "Player 5" },
          { "name": "Player 6" }
        ]
      },
      "description": "Full local six-player game on the default radius-two circle graph."
    },
    {
      "id": "cert-smoke",
      "name": "Certification Smoke",
      "parent_id": "default-5m",
      "game_config": {
        "seed": "liarliar-cert",
        "duration_seconds": 25,
        "tick_rate": 1,
        "player_connect_timeout_seconds": 10,
        "hint_redundancy": 1.3,
        "communication_graph": { "type": "circle", "radius": 2 },
        "hint_graph": { "type": "circle", "radius": 2 },
        "players": [
          { "name": "Player 1" },
          { "name": "Player 2" },
          { "name": "Player 3" },
          { "name": "Player 4" },
          { "name": "Player 5" },
          { "name": "Player 6" }
        ]
      },
      "description": "Short deterministic smoke episode used by certification."
    }
  ],
  "certification": {
    "game_config": {
      "seed": "liarliar-cert",
      "duration_seconds": 25,
      "tick_rate": 1,
      "player_connect_timeout_seconds": 10,
      "hint_redundancy": 1.3,
      "communication_graph": { "type": "circle", "radius": 2 },
      "hint_graph": { "type": "circle", "radius": 2 },
      "players": [
        { "name": "Player 1" },
        { "name": "Player 2" },
        { "name": "Player 3" },
        { "name": "Player 4" },
        { "name": "Player 5" },
        { "name": "Player 6" }
      ]
    },
    "players": [
      { "player_id": "scripted-helper" },
      { "player_id": "scripted-helper" },
      { "player_id": "scripted-helper" },
      { "player_id": "scripted-helper" },
      { "player_id": "scripted-helper" },
      { "player_id": "scripted-helper" }
    ]
  }
}
