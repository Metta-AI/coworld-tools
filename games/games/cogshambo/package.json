{
  "name": "cogshambo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "cogshambo": "dist-server/cli.js"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "preplay": "npm run build",
    "start": "node dist-server/server/index.js",
    "play": "node dist-server/cli.js play",
    "builder": "node dist-server/cli.js builder",
    "deploy:ec2": "scripts/deploy-main-to-ec2.sh",
    "init:db": "tsx src/cli/init-db.ts",
    "codex:builder": "tsx src/cli.ts builder",
    "art:sheet": "uv run --with replicate --with pillow python tools/generate_sprite_sheet.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "playwright test",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "playwright": "^1.59.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.0"
  }
}
